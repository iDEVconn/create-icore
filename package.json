{
  "name": "icore",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/auth-strategies/*",
    "libs/storage-strategies/*",
    "tools/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "^22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "^22.7.5",
    "@nx/nest": "^22.7.5",
    "@nx/node": "^22.7.5",
    "@nx/playwright": "^22.7.5",
    "@nx/react": "^22.7.5",
    "@nx/vite": "^22.7.5",
    "@nx/vitest": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/webpack": "^22.7.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^10.0.0",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^17.0.5",
    "nx": "22.7.5",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.0",
    "vitest": "^4",
    "webpack-cli": "^5.1.4"
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "dependencies": {
    "@casl/ability": "^7",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/microservices": "^11.1.24",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
