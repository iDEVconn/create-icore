# Transport (gateway ↔ this MS)
PAYMENT_TRANSPORT=tcp
PAYMENT_HOST=127.0.0.1
PAYMENT_PORT=4003
# PAYMENT_REDIS_URL=redis://localhost:6379
# PAYMENT_NATS_URL=nats://localhost:4222

# Which concrete PaymentStrategy to instantiate
PAYMENT_PROVIDER=paypal

# --- PayPal credentials (when PAYMENT_PROVIDER=paypal) ---
# Create REST API credentials in your PayPal Developer Dashboard:
#   https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox
