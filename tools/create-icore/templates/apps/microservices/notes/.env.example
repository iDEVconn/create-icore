# Transport (gateway ↔ this MS)
NOTES_TRANSPORT=tcp
NOTES_HOST=127.0.0.1
NOTES_PORT=4004
# NOTES_REDIS_URL=redis://localhost:6379
# NOTES_NATS_URL=nats://localhost:4222
# NOTES_MQTT_URL=mqtt://localhost:1883
# NOTES_RMQ_URL=amqp://localhost:5672
# NOTES_RMQ_QUEUE=notes_queue
# NOTES_KAFKA_BROKERS=localhost:9092
# NOTES_KAFKA_CLIENT_ID=notes

# Which DB to use — defaults to the root .env DB_PROVIDER if unset.
# Supabase Postgres, Firestore or MongoDB. Both honored by NotesController via DBStrategy.
DB_PROVIDER=supabase
# DB_PROVIDER=mongodb

# --- Credentials (mirror the auth MS) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FB_ADMIN_PROJECT_ID=
FB_ADMIN_CLIENT_EMAIL=
FB_ADMIN_PRIVATE_KEY=

# --- MongoDB credentials (when DB_PROVIDER=mongodb) ---
MONGODB_URI=mongodb://localhost:27017/icore
