{
  "name": "@idevconn/create-icore",
  "version": "0.1.1",
  "description": "Bootstrap a new project from the iCore scaffold (Nx + NestJS + React + Vite + shadcn/Tailwind, swappable auth + storage providers).",
  "license": "Apache-2.0",
  "author": "iDEVconn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iDEVconn/create-icore.git",
    "directory": "tools/create-icore"
  },
  "bugs": {
    "url": "https://github.com/iDEVconn/create-icore/issues"
  },
  "homepage": "https://github.com/iDEVconn/create-icore#readme",
  "type": "module",
  "keywords": [
    "icore",
    "scaffold",
    "bootstrap",
    "nestjs",
    "react",
    "vite",
    "shadcn",
    "tailwind",
    "supabase",
    "firebase",
    "cloudinary",
    "tanstack-router",
    "create-app"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": "./dist/cli.js",
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
