{
  "name": "icore-app",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "apps/*",
    "apps/microservices/*",
    "apps/templates/*",
    "libs/*",
    "libs/auth-strategies/*",
    "libs/storage-strategies/*",
    "libs/db-strategies/*"
  ],
  "scripts": {
    "dev": "nx run-many -t serve",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "remove-notes": "node tools/remove-notes.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@icore/vite-plugins": "*",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@nx/devkit": "22.7.5",
    "@nx/eslint": "^22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "^22.7.5",
    "@nx/nest": "^22.7.5",
    "@nx/node": "^22.7.5",
    "@nx/playwright": "^22.7.5",
    "@nx/react": "^22.7.5",
    "@nx/vite": "^22.7.5",
    "@nx/vitest": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/webpack": "^22.7.5",
    "@playwright/test": "^1.60.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.1",
    "@swc/core": "~1.15.41",
    "@swc/helpers": "~0.5.23",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "~30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.9",
    "eslint": "^9.18.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.8.3",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "husky": "^9.1.7",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.4.2",
    "lint-staged": "^17.0.8",
    "nx": "22.7.5",
    "prettier": "~3.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.1",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "~4.1.9",
    "webpack-cli": "^5.1.4"
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "dependencies": {
    "@casl/ability": "^7",
    "@casl/react": "^7.0.0",
    "@idevconn/api-client": "^0.3.0",
    "@idevconn/use-draft": "^0.2.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "axios": "^1.18.0",
    "classnames": "^2.5.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.21",
    "i18next": "^26.3.1",
    "react-i18next": "^17.0.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zustand": "^5.0.14"
  }
}
